# THEORY:
# Merging is used to combine multiple DataFrames.
# We use merge() function.

import pandas as pd

employees = pd.DataFrame({
    'ID': [1, 2, 3],
    'Name': ['John', 'Mary', 'Alex']
})

salaries = pd.DataFrame({
    'ID': [1, 2, 3],
    'Salary': [5000, 7000, 6500]
})

# Merging both DataFrames
merged_df = pd.merge(employees, salaries, on='ID')

print("Merged Data:")
print(merged_df)
