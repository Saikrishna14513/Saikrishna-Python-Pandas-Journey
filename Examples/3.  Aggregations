# THEORY:
# Basically, aggregations are used to perform mathematical calculations on data
# Some of the Common functions: sum(), mean(), max(), min()

import pandas as pd

data = {
    'Name': ['John', 'Mary', 'Alex'],
    'Salary': [5000, 7000, 6500]
}

df = pd.DataFrame(data)

# here we can see the Calculations
print("Total Salary:", df['Salary'].sum())
print("Average Salary:", df['Salary'].mean())
print("Maximum Salary:", df['Salary'].max())
print("Minimum Salary:", df['Salary'].min())
